<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Version>1.3.13</Version>
        
        <TargetFramework>netstandard2.1</TargetFramework>
        <RootNamespace>TinyUtilities</RootNamespace>
        
        <Nullable>disable</Nullable>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <IncludeBuildOutput>true</IncludeBuildOutput>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        
        <PackageId>com.ges.tinyutilities</PackageId>
        <Authors>Derek Sliman</Authors>
        
        <Description>Utilities pack.</Description>
        <PackageTags>utility;utilities;tools</PackageTags>
        
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        
        <NoWarn>$(NoWarn);1591</NoWarn>
        <ExternalDependencies Condition="'$(ExternalDependencies)' == ''">true</ExternalDependencies>
    </PropertyGroup>

    <PropertyGroup Condition="'$(ExternalDependencies)' == 'true'">
        <DefineConstants>$(DefineConstants);EXTERNAL_DEPENDENCIES</DefineConstants>
    </PropertyGroup>

    <ItemGroup Condition="'$(ExternalDependencies)' == 'true'">
        <PackageReference Include="System.Text.Json" Version="10.0.9" />
    </ItemGroup>
    
    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
    
</Project>
